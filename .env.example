# 엘리스 모집공고 알림 서비스 - 환경 변수 설정 가이드 (.env)
# 실제 설정 시에는 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.

# [카카오 API 기본 설정]
# 카카오 개발자 콘솔(https://developers.kakao.com) > 내 애플리케이션 > 앱 설정 > 앱 키
KAKAO_REST_API_KEY=your_rest_api_key_here

# 카카오 개발자 콘솔 > 내 애플리케이션 > 카카오 로그인 > 보안 (설정한 경우에만 입력)
KAKAO_CLIENT_SECRET=your_client_secret_here

# [나(본인)를 위한 설정]
# python setup_kakao.py 를 실행하여 발급받은 본인의 리프레시 토큰입니다.
# GitHub Actions 실행 시 이 토큰을 사용하여 본인에게 '나에게 보내기' 공지를 보냅니다.
KAKAO_REFRESH_TOKEN=your_own_refresh_token_here

# [친구(구독자)를 위한 설정]
# python add_subscriber.py 를 실행하고 친구가 승인한 코드를 입력하여 얻은 값입니다.
# 이 토큰이 설정되어 있으면 해당 친구에게도 공지가 전송됩니다.
KAKAO_FRIEND_REFRESH_TOKEN=your_friend_refresh_token_here

# [GitHub 자동화 설정]
# GitHub Actions가 실행 중 토큰을 갱신했을 때, 그 값을 다시 Secrets에 저장하기 위해 필요합니다.
# GitHub 계정 설정 > Developer settings > Personal access tokens (classic)에서 발급받으세요.
GH_PAT=your_github_personal_access_token_here
